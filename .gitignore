# Secretos y configuracion local - NUNCA subir al repositorio
docker/.env
docker/rclone/rclone.conf

# Carpeta de configuracion generada por SWAG (contiene certs y claves privadas)
docker/swag/
# Pero si sincronizar las configuraciones nginx personalizadas
!docker/swag/nginx/
!docker/swag/nginx/proxy-confs/
!docker/swag/nginx/proxy-confs/*.conf

# Carpeta de configuracion de WireGuard (contiene claves VPN)
docker/config/

# Datos de Docker volumes montados localmente
*.log
