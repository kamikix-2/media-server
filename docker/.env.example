# ============================================================
#  Configuracion del stack media-server
#  Copia este archivo a .env y rellena tus valores reales
#  cp .env.example .env
# ============================================================

# --- Zona horaria ---
TZ=Europe/Madrid

# --- Directorio donde esta rclone.conf en el HOST ---
RCLONE_CONFIG_DIR=./rclone

# --- Intervalo de sincronizacion rclone (en segundos) ---
SYNC_INTERVAL=3600

# --- Rutas de medios en el HOST ---
# Windows: C:/media-server/pelis
# Debian:  /opt/media-server/pelis
PELIS_DIR=/opt/media-server/pelis
CALIBRE_DIR=/opt/media-server/calibre-biblioteca
FOTOS_DIR=/opt/media-server/fotos
MUSICA_DIR=/opt/media-server/musica

# --- Jellyfin ---
JELLYFIN_HTTP_PORT=8096
JELLYFIN_HTTPS_PORT=8920

# --- Calibre ---
CALIBRE_WEBSERVER_PORT=8080
CALIBRE_DESKTOP_PORT=8181

# --- IDs de usuario/grupo para contenedores linuxserver ---
PUID=1000
PGID=1000

# --- Immich ---
IMMICH_PORT=2283
IMMICH_DB_PASSWORD=cambia_esta_password

# --- WireGuard ---
WIREGUARD_SERVERURL=tudominio.duckdns.org
WIREGUARD_SERVERPORT=51820
WIREGUARD_PEERS=1
WIREGUARD_PEERDNS=1.1.1.1
WIREGUARD_ALLOWEDIPS=0.0.0.0/0

# --- SSL gratis (Let's Encrypt + SWAG + DuckDNS) ---
# Subdominio base en DuckDNS (ej: si tu dominio es kamikix.duckdns.org, pon "kamikix")
SWAG_SUBDOMAIN=tusubdominio
# Token de DuckDNS (https://www.duckdns.org -> tu token)
DUCKDNS_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Email para notificaciones de Let's Encrypt
SWAG_EMAIL=tu-correo@ejemplo.com
